# Docker and server configuration
PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_SERVER_NAME=MCP OpenAPI Proxy
MCP_SERVER_DESCRIPTION=Automatically generated API from MCP Tool Schemas

# Config file path (optional)
MCP_CONFIG_PATH=/app/config.json

# MCP server command (optional)
MCP_COMMAND=mcp-server-time --local-timezone=America/Los_Angeles

# Config file to mount
CONFIG_FILE=./config.json

# Docker configuration
# DOCKER_CONFIG=~/.docker
